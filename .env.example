# No Azure connection environment variables are required.
# Azure projects and deployments are discovered dynamically on the server
# using DefaultAzureCredential and Azure Resource Manager APIs.

# ------------------------------------------------------------------------------
# Database provider
# ------------------------------------------------------------------------------
# Default remains SQLite when DATABASE_PROVIDER is not set.
# Supported providers: sqlite, postgresql, mysql, cockroachdb, sqlserver
# DATABASE_PROVIDER=sqlite
# LOCAL_PLAYGROUND_DATABASE_PROVIDER=sqlite

# ------------------------------------------------------------------------------
# SQLite (default)
# ------------------------------------------------------------------------------
# Optional database path override:
# LOCAL_PLAYGROUND_DATABASE_URL=file:/absolute/path/local-playground.sqlite

# ------------------------------------------------------------------------------
# Shared SQL authentication settings (for postgresql/mysql/cockroachdb)
# ------------------------------------------------------------------------------
# LOCAL_PLAYGROUND_DATABASE_AUTH_METHOD=password
# LOCAL_PLAYGROUND_DATABASE_AUTH_METHOD=azure_identity
# LOCAL_PLAYGROUND_DATABASE_AUTH_METHOD=access_token
#
# For azure_identity:
# LOCAL_PLAYGROUND_DATABASE_AZURE_IDENTITY_CLIENT_ID=<managed-identity-client-id>
# LOCAL_PLAYGROUND_DATABASE_AZURE_IDENTITY_SCOPE=https://ossrdbms-aad.database.windows.net/.default
#
# For access_token:
# LOCAL_PLAYGROUND_DATABASE_ACCESS_TOKEN=<database-access-token>

# ------------------------------------------------------------------------------
# PostgreSQL (connection URL)
# ------------------------------------------------------------------------------
# DATABASE_PROVIDER=postgresql
# LOCAL_PLAYGROUND_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# ------------------------------------------------------------------------------
# PostgreSQL (split connection vars)
# ------------------------------------------------------------------------------
# DATABASE_PROVIDER=postgresql
# LOCAL_PLAYGROUND_POSTGRES_HOST=HOST
# LOCAL_PLAYGROUND_POSTGRES_PORT=5432
# LOCAL_PLAYGROUND_POSTGRES_DATABASE=DBNAME
# LOCAL_PLAYGROUND_POSTGRES_USER=USER
# LOCAL_PLAYGROUND_POSTGRES_PASSWORD=PASSWORD
# LOCAL_PLAYGROUND_POSTGRES_SSLMODE=require
# LOCAL_PLAYGROUND_POSTGRES_SCHEMA=public
# LOCAL_PLAYGROUND_DATABASE_AUTH_METHOD=password

# ------------------------------------------------------------------------------
# MySQL (connection URL)
# ------------------------------------------------------------------------------
# DATABASE_PROVIDER=mysql
# LOCAL_PLAYGROUND_DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DBNAME
# LOCAL_PLAYGROUND_DATABASE_AUTH_METHOD=password

# ------------------------------------------------------------------------------
# CockroachDB (connection URL)
# ------------------------------------------------------------------------------
# DATABASE_PROVIDER=cockroachdb
# LOCAL_PLAYGROUND_DATABASE_URL=cockroachdb://USER:PASSWORD@HOST:26257/DBNAME?sslmode=require
# LOCAL_PLAYGROUND_DATABASE_AUTH_METHOD=password

# ------------------------------------------------------------------------------
# SQL Server (connection URL)
# Note: Local Playground currently supports only password mode for sqlserver.
# ------------------------------------------------------------------------------
# DATABASE_PROVIDER=sqlserver
# LOCAL_PLAYGROUND_DATABASE_URL=sqlserver://HOST:1433;database=DBNAME;user=USER;password=PASSWORD;encrypt=true
# LOCAL_PLAYGROUND_DATABASE_AUTH_METHOD=password
