# No Azure connection environment variables are required.
# Azure projects and deployments are discovered dynamically on the server
# using DefaultAzureCredential and Azure Resource Manager APIs.

# ------------------------------------------------------------------------------
# Database provider
# ------------------------------------------------------------------------------
# Default is SQLite when no PostgreSQL variables are configured.
# DATABASE_PROVIDER=sqlite
# LOCAL_PLAYGROUND_DATABASE_PROVIDER=sqlite

# ------------------------------------------------------------------------------
# SQLite (default)
# ------------------------------------------------------------------------------
# Optional database path override:
# LOCAL_PLAYGROUND_DATABASE_URL=file:/absolute/path/local-playground.sqlite

# ------------------------------------------------------------------------------
# PostgreSQL (connection URL + password auth)
# ------------------------------------------------------------------------------
# DATABASE_PROVIDER=postgresql
# LOCAL_PLAYGROUND_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# ------------------------------------------------------------------------------
# PostgreSQL (split connection vars + password auth)
# ------------------------------------------------------------------------------
# DATABASE_PROVIDER=postgresql
# LOCAL_PLAYGROUND_POSTGRES_HOST=HOST
# LOCAL_PLAYGROUND_POSTGRES_PORT=5432
# LOCAL_PLAYGROUND_POSTGRES_DATABASE=DBNAME
# LOCAL_PLAYGROUND_POSTGRES_USER=USER
# LOCAL_PLAYGROUND_POSTGRES_PASSWORD=PASSWORD
# LOCAL_PLAYGROUND_POSTGRES_SSLMODE=require
# LOCAL_PLAYGROUND_POSTGRES_SCHEMA=public
# LOCAL_PLAYGROUND_POSTGRES_AUTH_METHOD=password

# ------------------------------------------------------------------------------
# PostgreSQL (Azure Identity token auth)
# Supports DefaultAzureCredential flows (managed identity, service principal,
# Azure CLI login, etc.).
# ------------------------------------------------------------------------------
# DATABASE_PROVIDER=postgresql
# LOCAL_PLAYGROUND_POSTGRES_HOST=HOST
# LOCAL_PLAYGROUND_POSTGRES_DATABASE=DBNAME
# LOCAL_PLAYGROUND_POSTGRES_USER=USER
# LOCAL_PLAYGROUND_POSTGRES_AUTH_METHOD=azure_identity
# Optional: user-assigned managed identity client ID
# LOCAL_PLAYGROUND_POSTGRES_AZURE_IDENTITY_CLIENT_ID=<managed-identity-client-id>
# Optional: override token scope
# LOCAL_PLAYGROUND_POSTGRES_AZURE_IDENTITY_SCOPE=https://ossrdbms-aad.database.windows.net/.default

# ------------------------------------------------------------------------------
# PostgreSQL (direct access token auth)
# ------------------------------------------------------------------------------
# DATABASE_PROVIDER=postgresql
# LOCAL_PLAYGROUND_POSTGRES_HOST=HOST
# LOCAL_PLAYGROUND_POSTGRES_DATABASE=DBNAME
# LOCAL_PLAYGROUND_POSTGRES_USER=USER
# LOCAL_PLAYGROUND_POSTGRES_AUTH_METHOD=access_token
# LOCAL_PLAYGROUND_POSTGRES_ACCESS_TOKEN=<postgres-access-token>
